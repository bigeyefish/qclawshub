# Optional temporary publish allowlist.
# Comma/space/newline separated; supports Convex user ids (`users:...`),
# GitHub logins/handles (`alice` or `login:alice`), and GitHub numeric ids (`github:123456`).
PUBLISH_ALLOWLIST=
